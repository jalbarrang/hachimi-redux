{
  "servers": {
    "rust": {
      "command": "rust-analyzer",
      "extensions": ["rs"],
      "rootIndicators": ["Cargo.toml"],
      "initializationOptions": {
        "cargo": {
          "buildScripts": { "enable": true },
          "features": "all"
        },
        "check": {
          "command": "clippy"
        },
        "procMacro": {
          "enable": true
        }
      }
    }
  }
}
